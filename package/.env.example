# Copy this file to .env before running locally.
# Do not commit real API keys, passwords, or database files.

SERVER_HOST=0.0.0.0
SERVER_PORT=9800

REDIS_URL=redis://127.0.0.1:6379/0

OPENAI_API_KEY=replace-with-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

POLISH_MODEL=gpt-5
POLISH_API_KEY=
POLISH_BASE_URL=

ENHANCE_MODEL=gpt-5
ENHANCE_API_KEY=
ENHANCE_BASE_URL=

EMOTION_MODEL=
EMOTION_API_KEY=
EMOTION_BASE_URL=

HISTORY_COMPRESSION_THRESHOLD=5000
COMPRESSION_MODEL=gpt-5
COMPRESSION_API_KEY=
COMPRESSION_BASE_URL=

MAX_CONCURRENT_USERS=5
MAX_CONCURRENT_PER_USER=3
DEFAULT_USAGE_LIMIT=1
SEGMENT_SKIP_THRESHOLD=15
MAX_UPLOAD_FILE_SIZE_MB=0
API_REQUEST_INTERVAL=6
USE_STREAMING=false
THINKING_MODE_ENABLED=true
THINKING_MODE_EFFORT=high

PDF_FONT_PATH=
PDF_FONT_NAME=DocumentChineseFont

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
